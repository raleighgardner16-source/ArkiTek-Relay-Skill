{
  "name": "arkitek-relay-skill",
  "version": "1.0.12",
  "description": "Connect your OpenClaw agent to ArkiTek via secure outbound SSE relay",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "bin": {
    "arkitek-relay-skill": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "postinstall": "node scripts/postinstall.js"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "keywords": [
    "openclaw",
    "arkitek",
    "agent",
    "relay",
    "sse",
    "skill"
  ],
  "author": "raleighgardner16-source",
  "files": [
    "dist",
    "scripts/postinstall.js",
    ".env.example",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raleighgardner16-source/arkitek-relay-skill.git"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
